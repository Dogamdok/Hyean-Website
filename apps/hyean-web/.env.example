# Base URL
NEXT_PUBLIC_BASE_URL=https://hyean.org

# Analytics
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Firebase Client (public)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Server only
# JSON string (or base64-encoded JSON string) of Firebase service account key
FIREBASE_SERVICE_ACCOUNT_KEY=
FIRESTORE_INQUIRIES_COLLECTION=inquiries
GEMINI_API_KEY=

# Inquiry email notification (Dogamdok-compatible fallback included)
# If HYEAN_* is empty, EMAIL_USER/EMAIL_PASS/EMAIL_TO can be used.
HYEAN_INQUIRY_EMAIL_ENABLED=true
HYEAN_INQUIRY_EMAIL_USER=
HYEAN_INQUIRY_EMAIL_PASS=
HYEAN_INQUIRY_EMAIL_TO=
HYEAN_INQUIRY_EMAIL_FROM=
HYEAN_INQUIRY_EMAIL_SUBJECT_PREFIX=[혜안 웹사이트 문의]
HYEAN_INQUIRY_EMAIL_CC=
HYEAN_INQUIRY_EMAIL_BCC=
# Optional custom SMTP transport (if omitted, Gmail transport is used)
HYEAN_INQUIRY_SMTP_HOST=
HYEAN_INQUIRY_SMTP_PORT=587
HYEAN_INQUIRY_SMTP_SECURE=false

# Legacy-compatible aliases
EMAIL_USER=
EMAIL_PASS=
EMAIL_TO=

# API key used by n8n to publish insights via /api/posts
N8N_API_KEY=
